# =====================================================================
# SYNAPSE - Master Bootstrap Configuration
#
# Copy this file to .env.local and fill in values.
# Never commit .env.local to git.
#
# QUICK START:
#   1. Fill in LLM_PROVIDERS section below
#   2. Create a Supabase project and fill in SUPABASE section
#   3. Run: pnpm stellar:bootstrap
#   4. Copy the output values into the STELLAR section below
#   5. Run: pnpm agents:seed
#   6. Run: pnpm dev
#
# =====================================================================

# ---- LLM PROVIDERS (REQUIRED FOR DEMO) ----
# Get these from:
#   OpenAI:   https://platform.openai.com/account/api-keys
#   Anthropic: https://console.anthropic.com
#   NVIDIA NIM: https://build.nvidia.com/ai-endpoints

OPENAI_API_KEY=sk-...                    # GPT-4o Realtime + embeddings
ANTHROPIC_API_KEY=sk-ant-...            # Claude Sonnet 4.5 (planner)
NVIDIA_NIM_API_KEY=nvapi-...            # Llama 3.3 70B (agent execution)
ELEVENLABS_API_KEY=                     # Optional: TTS backup

# ---- STELLAR TESTNET (Filled by `pnpm stellar:bootstrap`) ----
STELLAR_NETWORK=TESTNET
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_PASSPHRASE=Test SDF Network ; September 2015

# These are generated by bootstrap script (S... format = secret key, G... = public)
PLATFORM_TREASURY_PUBLIC=G...            # Platform account that funds agents
PLATFORM_TREASURY_SECRET=S...            # KEEP SECRET. Do NOT commit.

# ---- SUPABASE (PostgreSQL + pgvector + Auth) ----
# Create free project at https://supabase.com
# After creating project, find credentials in Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...  # Public key (safe for browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...     # Service role (server-only, secrets)

# ---- APPLICATION ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_BRIDGE_URL=ws://localhost:8080

# ---- VOICE BRIDGE (Fastify WS Server) ----
VOICE_BRIDGE_PORT=8080
LOG_LEVEL=info

# =====================================================================
# BOOTSTRAP WORKFLOW
# =====================================================================
#
# Step 1: Fill in LLM_PROVIDERS + SUPABASE sections above
#
# Step 2: Run database migrations
#   pnpm db:migrate
#
# Step 3: Generate Stellar bootstrap (treasury)
#   pnpm stellar:bootstrap
#   -> Prints env vars to console. Copy them into this file.
#   -> Creates .stellar/bootstrap.json (idempotent)
#
# Step 4: Seed 12 demo agents with keypairs, fund, embed
#   pnpm agents:seed
#   -> Generates agent keypairs
#   -> Funds via Friendbot (10k XLM each)
#   -> Creates OpenAI embeddings
#   -> Inserts into agents table
#
# Step 5: Start all services (3 terminals)
#   Terminal 1: pnpm dev:web        # http://localhost:3000
#   Terminal 2: pnpm dev:bridge     # ws://localhost:8080
#   Terminal 3: pnpm dev:mobile     # Expo (choose iOS/Android/Web)
#
# Step 6: Try demo
#   -> Go to http://localhost:3000
#   -> Click "Try demo"
#   -> Speak a goal (e.g., "Find flights from SFO to NYC")
#   -> Watch the Voice Orb, Plan Tree, Agent Graph, Cost Meter, Tx Feed
#   -> Hear the narrated result in OpenAI voice
#   -> Click tx hashes to see real Stellar txs at stellar.expert
#
# =====================================================================
