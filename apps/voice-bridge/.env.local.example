# =====================================================================
# voice-bridge — .env.local
# Copy to .env.local and fill in your values.
# =====================================================================

# Port the WS server listens on
VOICE_BRIDGE_PORT=8080

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# OpenAI API key (used by clients to request ephemeral session tokens)
# Typically this is the same OPENAI_API_KEY from the web app
OPENAI_API_KEY=sk-...

# Optional: correlate logs with parent app
NEXT_PUBLIC_APP_URL=http://localhost:3000
