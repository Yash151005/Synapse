# =====================================================================
# apps/mobile — .env.local.example
# Expo mobile client config. Copy to .env.local and fill in values.
# =====================================================================

# Backend
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_WS_BRIDGE_URL=ws://localhost:8080

# Stellar Network
EXPO_PUBLIC_STELLAR_NETWORK=TESTNET
EXPO_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Supabase (for agent registry)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Optional: Freighter wallet proxy
EXPO_PUBLIC_FREIGHTER_ENABLED=false
